// Importe le service en haut du fichier
import { AuthService } from '../services'; // Vérifie le chemin vers ton fichier services

const handleSubmit = async (e) => {
    e.preventDefault();
    setIsLoading(true);
    setError(false);

    // On utilise maintenant le vrai service d'authentification
    const result = await AuthService.login(creds.user, creds.pass);

    if (result.success) {
        // Succès : On déclenche la fonction du parent
        onLogin();
    } else {
        // Échec
        setError(true);
        setIsLoading(false);
        // Reset l'erreur après 3s
        setTimeout(() => setError(false), 3000);
    }
};